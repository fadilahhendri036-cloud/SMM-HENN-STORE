    padding: 32px 36px;
    margin-top: 48px;
    position: relative;
    overflow: hidden;
    backdrop-filter: blur(20px);
  }

  .premium-notice-box::before {
    content: '';
    position: absolute;
    top: 0; left: 0; right: 0;
    height: 1px;
    background: linear-gradient(90deg, transparent, rgba(255,215,0,0.5), transparent);
  }

  .premium-notice-title {
    font-family: 'Syne', sans-serif;
    font-weight: 800;
    font-size: 1.15rem;
    color: #ffd700;
    margin-bottom: 20px;
    display: flex;
    align-items: center;
    gap: 10px;
  }

  .premium-notice-list {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 10px;
  }

  .premium-notice-list li {
    display: flex;
    gap: 10px;
    font-size: 0.88rem;
    color: var(--silver);
    line-height: 1.5;
  }

  .premium-notice-list li::before {
    content: '›';
    color: rgba(255,215,0,0.6);
    font-weight: 700;
    flex-shrink: 0;
    font-family: 'Space Mono', monospace;
    margin-top: 1px;
  }

  /* ─── PREMIUM ORDER FORM ADDITIONS ─── */
  .order-category-tabs {
    display: flex;
    gap: 4px;
    margin-bottom: 28px;
    background: var(--dark2);
    border: 1px solid var(--border);
    border-radius: 10px;
