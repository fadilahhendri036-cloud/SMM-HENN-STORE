  .qty-counter {
    display: flex;
    align-items: center;
    gap: 0;
    background: var(--dark2);
    border: 1px solid var(--border);
    border-radius: 10px;
    overflow: hidden;
    width: 100%;
  }

  .qty-btn {
    background: var(--dark3);
    border: none;
    color: var(--white);
    font-size: 1.3rem;
    font-weight: 700;
    width: 52px;
    height: 48px;
    cursor: pointer;
    transition: background 0.2s, color 0.2s;
    flex-shrink: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: 'DM Sans', sans-serif;
    line-height: 1;
  }

  .qty-btn:hover {
    background: var(--pure-white);
    color: var(--black);
  }

  .qty-btn:active {
    transform: scale(0.96);
  }

  .qty-counter input[type="number"] {
    border: none;
    border-radius: 0;
    border-left: 1px solid var(--border);
    border-right: 1px solid var(--border);
    text-align: center;
    font-family: 'Space Mono', monospace;
    font-weight: 700;
    font-size: 1.1rem;
    color: var(--pure-white);
    flex: 1;
    min-width: 0;
    background: var(--dark2);
    padding: 12px 8px;
    pointer-events: none;
  }

  .qty-counter input[type="number"]::-webkit-inner-spin-button,
  .qty-counter input[type="number"]::-webkit-outer-spin-button { -webkit-appearance: none; }

