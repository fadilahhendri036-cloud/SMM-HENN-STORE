  .notes-card:hover {
    border-color: var(--border2);
    box-shadow: 0 8px 32px rgba(124,58,237,0.1);
  }

  .notes-platform {
    font-family: 'Syne', sans-serif;
    font-weight: 800;
    font-size: 1.1rem;
    margin-bottom: 20px;
    display: flex;
    align-items: center;
    gap: 10px;
  }

  .notes-list {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 10px;
  }

  .notes-list li {
    font-size: 0.88rem;
    color: var(--silver);
    display: flex;
    gap: 10px;
    line-height: 1.5;
  }

  .notes-list li::before {
    content: '—';
    color: var(--gray3);
    flex-shrink: 0;
    margin-top: 1px;
    font-family: 'Space Mono', monospace;
  }

  .notes-steps {
    margin-top: 16px;
    padding-top: 16px;
    border-top: 1px solid var(--border);
  }

  .notes-steps p {
    font-size: 0.8rem;
    color: var(--gray4);
    margin-bottom: 10px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.08em;
  }

  .notes-steps ol {
    padding-left: 0;
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  .notes-steps ol li {
    font-size: 0.84rem;
    color: var(--silver);
    display: flex;
    gap: 12px;
    line-height: 1.5;
  }

  .step-num {
    background: var(--gradient3);
    border-radius: 50%;
    width: 22px;
    height: 22px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 0.65rem;
    font-weight: 700;
    flex-shrink: 0;
    margin-top: 1px;
    font-family: 'Space Mono', monospace;
    color: white;
  }

  /* ─── FAQ ─── */
  #faq {
    padding: 100px 0;
    border-top: 1px solid var(--border);
  }

  .faq-list {
    max-width: 720px;
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  .faq-item {
    background: var(--glass);
    border: 1px solid var(--border);
    border-radius: 14px;
    overflow: hidden;
    backdrop-filter: blur(10px);
    transition: border-color 0.2s;
  }

  .faq-item.open { border-color: var(--accent); box-shadow: 0 4px 24px rgba(167,139,250,0.1); }

  .faq-q {
    width: 100%;
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 20px 24px;
    background: none;
    border: none;
    color: var(--white);
    font-family: 'DM Sans', sans-serif;
    font-size: 0.95rem;
    font-weight: 600;
    cursor: pointer;
    text-align: left;
    gap: 16px;
  }

  .faq-icon {
    width: 28px;
    height: 28px;
    background: var(--dark3);
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    font-size: 1.1rem;
    transition: transform 0.3s, background 0.2s;
    color: var(--silver);
  }

  .faq-item.open .faq-icon {
    transform: rotate(45deg);
    background: var(--pure-white);
    color: var(--black);
  }

  .faq-a {
    display: none;
    padding: 0 24px 20px;
    color: var(--gray4);
    font-size: 0.9rem;
    line-height: 1.7;
  }

  .faq-item.open .faq-a { display: block; }

  /* ─── CONTACT ─── */
  #contact {
    padding: 100px 0;
    border-top: 1px solid var(--border);
  }

  .contact-cards {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(260px, 1fr));
    gap: 20px;
    max-width: 700px;
  }

  .contact-card {
    background: var(--glass);
    border: 1px solid var(--border);
    border-radius: 20px;
    padding: 32px 28px;
    backdrop-filter: blur(20px);
    transition: all 0.3s;
    text-decoration: none;
    color: inherit;
    display: block;
  }

  .contact-card:hover {
    border-color: var(--accent);
    transform: translateY(-6px);
    background: var(--glass2);
    box-shadow: 0 16px 48px rgba(124,58,237,0.2);
  }

  .contact-icon {
    width: 36px;
    height: 36px;
    display: flex;
    align-items: center;
    color: var(--silver);
    margin-bottom: 16px;
  }

  .contact-platform {
    font-family: 'Space Mono', monospace;
    font-size: 0.7rem;
    color: var(--gray3);
    text-transform: uppercase;
    letter-spacing: 0.15em;
    margin-bottom: 6px;
  }

  .contact-handle {
    font-family: 'Syne', sans-serif;
    font-weight: 700;
    font-size: 1.1rem;
    color: var(--white);
  }

  /* ─── FOOTER ─── */
  <footer>
    border-top: 1px solid var(--border);
    padding: 48px 0;
    position: relative;
    z-index: 1;
  }

  .footer-inner {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 24px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: 16px;
  }

  .footer-logo {
    font-family: 'Syne', sans-serif;
    font-weight: 800;
    font-size: 1.1rem;
    color: var(--pure-white);
    letter-spacing: 0.1em;
  }

  .footer-copy {
    font-size: 0.82rem;
    color: var(--gray3);
    text-align: center;
  }

  .footer-tagline {
    font-size: 0.82rem;
    color: var(--gray3);
    font-style: italic;
  }

  /* ─── FLOATING WA ─── */
  .floating-wa {
    position: fixed;
    bottom: 32px;
    right: 32px;
    z-index: 900;
    width: 56px;
    height: 56px;
    background: #25D366;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    box-shadow: 0 4px 20px rgba(37, 211, 102, 0.4);
    text-decoration: none;
    transition: all 0.25s ease;
    animation: floatIn 0.6s ease 1s both;
  }

  .floating-wa:hover {
    transform: scale(1.12);
    box-shadow: 0 8px 32px rgba(37, 211, 102, 0.5);
  }

  .floating-wa svg { width: 28px; height: 28px; fill: #000; }

  @keyframes floatIn {
    from { opacity: 0; transform: translateY(20px) scale(0.8); }
    to { opacity: 1; transform: translateY(0) scale(1); }
  }

  /* ─── ANIMATIONS ─── */
  @keyframes fadeInUp {
    from { opacity: 0; transform: translateY(30px); }
    to { opacity: 1; transform: translateY(0); }
  }

  @keyframes fadeInDown {
    from { opacity: 0; transform: translateY(-20px); }
    to { opacity: 1; transform: translateY(0); }
  }

  .reveal {
    opacity: 0;
    transform: translateY(24px);
    transition: opacity 0.6s ease, transform 0.6s ease;
  }

  .reveal.visible {
    opacity: 1;
    transform: translateY(0);
  }

  /* ─── RESPONSIVE ─── */
  @media (max-width: 768px) {
    .nav-links { display: none; }
    .hamburger { display: flex; }

    .calc-grid { grid-template-columns: 1fr; }
    .calc-result-grid { grid-template-columns: 1fr 1fr; }

    .footer-inner { flex-direction: column; text-align: center; }
    .floating-wa { bottom: 20px; right: 20px; width: 50px; height: 50px; }
    .floating-wa svg { width: 24px; height: 24px; }

    .calc-wrapper, .order-wrapper { padding: 28px 20px; }
    .services-tabs { width: 100%; }
    .tab-btn { flex: 1; text-align: center; padding: 10px 12px; font-size: 0.78rem; }

    .order-total-display { flex-direction: column; gap: 4px; text-align: center; }
    .order-total-display .amount { font-size: 1.3rem; }
  }

  @media (max-width: 480px) {
    .calc-result-grid { grid-template-columns: 1fr; }
    .hero-title { font-size: 2.8rem; }
  }

  /* ─── DIVIDER ─── */
  .section-divider {
    height: 1px;
    background: linear-gradient(90deg, transparent, var(--border2), transparent);
    margin: 0;
  }

  /* ─── PLATFORM ACCENT COLORS ─── */
  .tiktok-accent { color: var(--tiktok); }
  .instagram-accent { color: #E1306C; }
  .whatsapp-accent { color: var(--whatsapp); }

  /* ─── PREMIUM APPS SECTION ─── */
  #premium-apps {
    padding: 100px 0;
    border-top: 1px solid var(--border);
    position: relative;
  }

  #premium-apps::before {
    content: '';
    position: absolute;
    top: 0; left: 50%;
