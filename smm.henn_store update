    border: 1px solid rgba(74, 222, 128, 0.3);
    color: #4ade80;
    border-radius: 100px;
    padding: 4px 12px;
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    margin-bottom: 16px;
    font-family: 'Space Mono', monospace;
  }

  .qr-active-badge::before {
