function calcCompute() {
  const platform = document.getElementById('calc-platform').value;
  const service = document.getElementById('calc-service').value;
  const qty = parseInt(document.getElementById('calc-qty').value) || 0;
  const errEl = document.getElementById('calc-error');

  if (!platform || !service || !SERVICES[platform] || !SERVICES[platform][service]) {
    document.getElementById('res-unit').textContent = '—';
    document.getElementById('res-min').textContent = '—';
    document.getElementById('res-max').textContent = '—';
    document.getElementById('res-qty').textContent = '—';
    document.getElementById('res-total').textContent = 'Rp0';
    errEl.classList.remove('show');
    return;
  }

  const cfg = SERVICES[platform][service];
  document.getElementById('res-unit').textContent = formatRp(cfg.price);
  document.getElementById('res-min').textContent = formatNum(cfg.min);
  document.getElementById('res-max').textContent = formatNum(cfg.max);

  if (qty > 0) {
    document.getElementById('res-qty').textContent = formatNum(qty);
    if (qty < cfg.min) {
      errEl.classList.add('show');
      document.getElementById('res-total').textContent = 'Rp0';
    } else if (qty > cfg.max) {
      errEl.textContent = 'Jumlah melebihi maksimum order.';
      errEl.classList.add('show');
      document.getElementById('res-total').textContent = 'Rp0';
    } else {
      errEl.classList.remove('show');
      document.getElementById('res-total').textContent = formatRp(qty * cfg.price);
    }
  } else {
    document.getElementById('res-qty').textContent = '—';
    document.getElementById('res-total').textContent = 'Rp0';
    errEl.classList.remove('show');
  }
}

