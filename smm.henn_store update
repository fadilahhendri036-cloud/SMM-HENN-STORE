  }

  .premium-app-name {
    font-family: 'Syne', sans-serif;
    font-weight: 800;
    font-size: 1.1rem;
    color: var(--pure-white);
    margin-bottom: 6px;
  }

  .premium-app-desc {
    font-size: 0.82rem;
    color: var(--gray4);
    line-height: 1.6;
    margin-bottom: 16px;
    font-weight: 300;
  }

  .premium-packages {
    display: flex;
    flex-direction: column;
    gap: 8px;
    margin-bottom: 16px;
  }

  .premium-package-row {
    display: flex;
    align-items: center;
    justify-content: space-between;
    background: rgba(255,255,255,0.03);
    border: 1px solid rgba(255,255,255,0.07);
    border-radius: 10px;
    padding: 10px 14px;
    transition: all 0.2s;
    cursor: pointer;
    gap: 8px;
  }

  .premium-package-row:hover {
    background: rgba(255,215,0,0.06);
    border-color: rgba(255,215,0,0.2);
  }

  .premium-package-name {
    font-size: 0.82rem;
    color: var(--silver);
    font-weight: 500;
    flex: 1;
  }

  .premium-package-price {
    font-family: 'Space Mono', monospace;
    font-size: 0.88rem;
    font-weight: 700;
    color: #ffd700;
    white-space: nowrap;
  }

  .package-order-btn {
    background: transparent;
    border: 1px solid rgba(255,215,0,0.25);
    color: #ffd700;
    border-radius: 6px;
    padding: 3px 8px;
    font-size: 0.65rem;
    font-weight: 700;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    cursor: pointer;
    font-family: 'Space Mono', monospace;
    transition: all 0.2s;
    white-space: nowrap;
  }

  .package-order-btn:hover {
    background: rgba(255,215,0,0.12);
    border-color: rgba(255,215,0,0.5);
  }

  .premium-card-labels {
    display: flex;
    flex-wrap: wrap;
