  .qr-instruction {
    font-size: 0.85rem;
    color: var(--silver);
    line-height: 1.6;
    margin-bottom: 8px;
  }

  .qr-amount-label {
    font-family: 'Space Mono', monospace;
    font-size: 0.75rem;
    color: var(--gray4);
    text-transform: uppercase;
    letter-spacing: 0.1em;
    margin-bottom: 4px;
  }

  .qr-amount-value {
    font-family: 'Syne', sans-serif;
    font-size: 1.8rem;
    font-weight: 800;
