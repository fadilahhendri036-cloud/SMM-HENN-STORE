  }

  .premium-section-header {
    margin-bottom: 24px;
  }

  .premium-badge-row {
    display: flex;
    gap: 10px;
    flex-wrap: wrap;
    margin-top: 20px;
    margin-bottom: 48px;
  }

  .premium-feature-badge {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    padding: 6px 14px;
    border-radius: 100px;
