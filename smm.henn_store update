  .order-cat-btn {
    padding: 9px 20px;
    border-radius: 7px;
    border: none;
    background: transparent;
    color: var(--gray4);
    font-family: 'DM Sans', sans-serif;
    font-size: 0.82rem;
    font-weight: 600;
    cursor: pointer;
    transition: all 0.2s;
    white-space: nowrap;
  }

  .order-cat-btn.active {
    background: var(--gradient);
    color: var(--pure-white);
    box-shadow: 0 4px 20px rgba(124,58,237,0.4);
  }

  .order-cat-btn:hover:not(.active) {
    color: var(--white);
    background: var(--gray1);
  }

  .order-panel { display: none; }
  .order-panel.active { display: block; }

  .premium-order-fields {
    display: flex;
    flex-direction: column;
    gap: 16px;
  }

  .premium-order-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 16px;
  }

