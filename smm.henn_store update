    display: none;
    margin-top: 20px;
    background: var(--dark2);
    border: 1px solid var(--border2);
    border-radius: 16px;
    padding: 28px 24px;
    text-align: center;
    animation: fadeInUp 0.4s ease both;
  }

  .qr-payment-box.show { display: block; }

  .qr-payment-title {
    font-family: 'Syne', sans-serif;
    font-weight: 800;
    font-size: 1rem;
    color: var(--pure-white);
    margin-bottom: 6px;
    letter-spacing: 0.04em;
  }

  .qr-active-badge {
    display: inline-flex;
    align-items: center;
    gap: 6px;
